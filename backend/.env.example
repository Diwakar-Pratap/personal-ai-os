# ============================================================
# Personal AI OS — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
MODEL_NAME=gpt-4o-mini

# --- Memory ---
MAX_SHORT_TERM_MESSAGES=10

# --- Database Storage ---
# Path to your OneDrive folder where the SQLite DB will be saved
# It will auto-sync to Microsoft OneDrive for free cloud backup
ONEDRIVE_PATH=C:\Users\Diwakar\OneDrive\PersonalAI

# --- ngrok (for phone access) ---
# Get free token at https://dashboard.ngrok.com/get-started/your-authtoken
ENABLE_NGROK=true
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# --- Server ---
HOST=0.0.0.0
PORT=8000
